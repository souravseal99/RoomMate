{
  "compilerOptions": {
    "lib": [
      "ES2022"
    ],
    "target": "ES2022",
    "skipLibCheck": true,
    "module": "esnext",
    "baseUrl": "./src",
    "rootDir": "../",
    "paths": {
      "@src/*": [
        "./*"
      ],
      "@common/*": [
        "./common/*"
      ],
      "@types/*": [
        "./common/types/*"
      ],
      "@generated/*": [
        "../generated/*"
      ],
      "@config/*": [
        "./config/*"
      ],
      "@test/*": [
        "../test/*"
      ]
    },
    "outDir": "./build",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": [
    "src",
    "tests"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "cfn",
    "**/*.test.ts"
  ],
  "ts-node": {
    // Do not forget to `npm i -D tsconfig-paths`
    "require": [
      "tsconfig-paths/register"
    ]
  }
}