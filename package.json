{
  "name": "roommate",
  "private": true,
  "type": "module",
  "workspaces": [
    "roommate-app",
    "roommate-server"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^6.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript-eslint": "^8.62.0"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:app": "eslint roommate-app",
    "lint:server": "eslint roommate-server",
    "lint:fix": "eslint . --fix",
    "format:check": "npm run format:check --workspace=roommate-app",
    "type-check:app": "npm run type-check --workspace=roommate-app",
    "type-check:server": "npm run type-check --workspace=roommate-server",
    "type-check": "npm run type-check:app && npm run type-check:server",
    "build:app": "npm run build --workspace=roommate-app",
    "test": "npm test --workspace=roommate-server"
  }
}